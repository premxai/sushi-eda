# Sushi environment for docker-compose.
# Copy to .env before running `docker compose up` (compose requires the file):
#     cp .env.example .env
#
# ALL VALUES ARE OPTIONAL. With everything left blank the stack runs in
# open demo mode: SQLite database, local file storage, no authentication,
# AI features disabled. Fill in sections only as you need them.

# ── Database ──────────────────────────────────────────────────────────────────
# Any Postgres URL. Leave blank to use the built-in SQLite fallback (/tmp/sushi).
DATABASE_URL=

# ── Auth (Clerk) — leave blank for open demo mode ─────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys.
# Setting these enables real sign-in on the frontend and JWT checks on the API.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── AI (Anthropic Claude) — leave blank to disable AI features ────────────────
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
# Anti-abuse caps for public no-auth deployments (calls per UTC day)
AI_DAILY_LIMIT_PER_IP=20
AI_DAILY_BUDGET_CALLS=500

# ── Data retention ─────────────────────────────────────────────────────────────
# Uploaded files + reports are deleted after this many days (0 = keep forever)
RETENTION_DAYS=7

# ── Storage (Cloudflare R2 / S3-compatible) ───────────────────────────────────
# Leave blank to store uploads on the local filesystem (/tmp/sushi/storage).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Billing (Stripe) — optional ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# ── Observability (Sentry) — optional ─────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Data Connectors — optional ────────────────────────────────────────────────
# 32-byte base64 key for Fernet encryption of connector credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_SECRET_KEY=

# ── Slack — optional ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SUSHI_API_URL=http://backend:8000

# ── GitHub Integration — optional ─────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_ORG_ID=default

# ── App ───────────────────────────────────────────────────────────────────────
# Set ENVIRONMENT=production for real deployments; production REQUIRES
# ALLOWED_ORIGINS (comma-separated frontend origins) or all CORS is blocked.
ENVIRONMENT=development
ALLOWED_ORIGINS=
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shareable link TTL (seconds). Default: 7 days
SHARE_TTL_SECONDS=604800

# Note: REDIS_URL / CELERY_* are injected by docker-compose automatically.
