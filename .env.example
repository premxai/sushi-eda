# ── Database (Supabase / any Postgres) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
# Override only if using an external Redis (docker-compose sets this automatically)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth (Clerk) ───────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
# Frontend
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Storage (Cloudflare R2 / S3-compatible) ────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=sushi-datasets
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS_NARRATIVE=1024
AI_MAX_TOKENS_CLEANING=2048
AI_MAX_TOKENS_CHAT=2048

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...

# ── Observability (Sentry) ────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=sushi-backend
# Frontend
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Data Connectors ───────────────────────────────────────────────────────────
# 32-byte base64 key for Fernet encryption of connector credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_SECRET_KEY=your_32_byte_base64_key_here

# ── Monitors / Alerts ─────────────────────────────────────────────────────────
# Slack Incoming Webhook URL for monitor alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Slack Bot ─────────────────────────────────────────────────────────────────
# From Slack app Basic Information → App Credentials
SLACK_SIGNING_SECRET=your_slack_signing_secret
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# Internal URL the Slack bot uses to call our own API
SUSHI_API_URL=http://backend:8000

# ── GitHub Integration ────────────────────────────────────────────────────────
# Secret set in GitHub repo Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
# Default org to assign GitHub-imported datasets (when no repo→org mapping exists)
GITHUB_DEFAULT_ORG_ID=default
# Optional: map repos to org IDs — comma-separated "owner/repo:org_id" pairs
# GITHUB_ORG_MAP=myco/data-repo:org_abc123,myco/ml-repo:org_def456

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com
NEXT_PUBLIC_API_URL=/api
BACKEND_URL=https://api.your-domain.com
NEXT_PUBLIC_SITE_URL=https://sushi-eda.com

# Shareable link TTL (seconds). Default: 7 days
SHARE_TTL_SECONDS=604800

# Sentry release tag (set by CI, e.g. git SHA)
SENTRY_RELEASE=sushi@1.0.0
