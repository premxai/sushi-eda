# Sushi backend environment.
# ALL VALUES ARE OPTIONAL — with nothing set the API runs in open demo mode.
# Each entry below documents its fallback behavior when left blank.

# ── Database ──────────────────────────────────────────────────────────────────
# Any Postgres URL (postgres:// and postgresql:// are auto-converted to asyncpg).
# Blank → SQLite fallback at /tmp/sushi/sushi.db (single-instance demo only).
DATABASE_URL=

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get from: Clerk Dashboard → API Keys.
# Blank → OPEN demo mode: every request acts as a shared demo user.
# Strongly recommended for any publicly reachable deployment.
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Blank/unreachable → in-memory fallbacks for job status, analysis cache and
# share links (single-process only; run uvicorn with one worker), and the
# Celery async path is replaced by inline synchronous analysis.
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── File Storage (Cloudflare R2 / S3-compatible) ──────────────────────────────
# Blank → uploads stored on the local filesystem (LOCAL_STORAGE_DIR,
# default /tmp/sushi/storage).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Blank → AI narrative/chat/cleaning-suggestion features are disabled.
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# ── Billing (Stripe) — optional ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# ── App ───────────────────────────────────────────────────────────────────────
# ENVIRONMENT=production REQUIRES ALLOWED_ORIGINS (comma-separated origins),
# otherwise all cross-origin requests are blocked.
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# Shareable link TTL (seconds). Default: 7 days
SHARE_TTL_SECONDS=604800
