# Sushi backend environment — copy to backend/.env for local development.
# Loaded by main.py at startup (real environment variables take precedence).
# ALL VALUES ARE OPTIONAL — with nothing set the API runs in open demo mode.

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# THE key that unlocks the AI summary + "Ask Your Data" chat.
# Blank → those features are disabled (everything else still works).
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
# Anti-abuse caps for public deployments (calls per UTC day)
AI_DAILY_LIMIT_PER_IP=20
AI_DAILY_BUDGET_CALLS=500

# ── Data retention ────────────────────────────────────────────────────────────
# Uploads + reports auto-delete after this many days (0 = keep forever).
RETENTION_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# Any Postgres URL (postgres:// and postgresql:// are auto-converted to asyncpg).
# Blank → SQLite fallback in the system temp dir (single-instance demo only).
DATABASE_URL=

# ── File Storage (Cloudflare R2 / S3-compatible) ──────────────────────────────
# Blank → uploads stored on the local filesystem (LOCAL_STORAGE_DIR,
# default <temp>/sushi/storage).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Blank/unreachable → in-memory fallbacks for job status, analysis cache and
# share links. Fine for a single instance; required before scaling out.
REDIS_URL=

# ── Auth (Clerk) — Phase 4, leave blank until then ────────────────────────────
CLERK_SECRET_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# ENVIRONMENT=production REQUIRES ALLOWED_ORIGINS (comma-separated origins),
# otherwise all cross-origin requests are blocked.
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# Shareable link TTL (seconds). Default: 7 days
SHARE_TTL_SECONDS=604800

# ── Observability — optional ──────────────────────────────────────────────────
SENTRY_DSN=
