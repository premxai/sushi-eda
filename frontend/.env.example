# Sushi frontend environment.
# ALL VALUES ARE OPTIONAL. With no env file at all the app builds and runs
# against a local backend at http://localhost:8000.

# ── Backend API ───────────────────────────────────────────────────────────────
# Browser-visible API base. Use "/api" to proxy through Next.js rewrites,
# or a full URL like http://localhost:8000 to hit the backend directly.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side rewrite target used when NEXT_PUBLIC_API_URL=/api.
BACKEND_URL=http://localhost:8000

# ── Site Configuration (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
