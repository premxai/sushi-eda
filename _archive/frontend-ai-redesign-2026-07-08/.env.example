# Sushi frontend environment.
# ALL VALUES ARE OPTIONAL. With no env file at all the app builds and runs in
# open demo mode (no sign-in; everyone is a shared demo user).

# ── Backend API ───────────────────────────────────────────────────────────────
# Browser-visible API base. Use "/api" to proxy through Next.js rewrites,
# or a full URL like http://localhost:8000 to hit the backend directly.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side rewrite target used when NEXT_PUBLIC_API_URL=/api.
BACKEND_URL=http://localhost:8000

# ── Clerk (Auth) — leave blank for open demo mode ─────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys.
# Setting the publishable key enables real auth (middleware, sign-in/up pages);
# the backend needs the matching CLERK_SECRET_KEY too.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect paths (optional - defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Site Configuration (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
